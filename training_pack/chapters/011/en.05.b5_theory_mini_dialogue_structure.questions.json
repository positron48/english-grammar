    {
      "type": "mcq_single",
      "prompt": "Какой порядок элементов в мини-диалоге является правильным?",
      "choices": [
        {
          "id": "a",
          "text": "Приветствие → Представление → Обмен информацией → Завершение"
        },
        {
          "id": "b",
          "text": "Представление → Приветствие → Завершение → Обмен информацией"
        },
        {
          "id": "c",
          "text": "Обмен информацией → Завершение → Приветствие → Представление"
        },
        {
          "id": "d",
          "text": "Завершение → Приветствие → Представление → Обмен информацией"
        }
      ],
      "correct_answer": "a",
      "explanation": "Правильная структура мини-диалога: 1) Приветствие (Hello/Hi), 2) Представление (I am... / My name is...), 3) Обмен информацией, 4) Завершение (Goodbye). Остальные варианты нарушают логическую последовательность.",
      "theory_block_id": "b5_theory_mini_dialogue_structure",
      "chapter_id": "en.grammar.first_sentences_be_as.build_speak_mini_dialogues",
